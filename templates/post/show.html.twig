{% extends 'base.html.twig' %}

{% block title %}{{ post.title }} - Les Chroniques du Code{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-12 col-lg-9">
            <article class="animate-fade-in">
                <header class="mb-5 text-center">
                    {% if preview is not defined or not preview %}
                        <div class="mb-3">
                            <a href="{{ path('app_post_index') }}" class="btn btn-link text-decoration-none p-0 transition-base">
                                <i class="bi bi-arrow-left me-1"></i> Retour à la liste
                            </a>
                        </div>
                    {% else %}
                        <div class="alert alert-info shadow-sm mb-4">
                            <i class="bi bi-eye me-2"></i> Mode prévisualisation - cet article n'est pas encore enregistré.
                        </div>
                    {% endif %}

                    <h1 class="display-4 fw-bold text-dark mb-3">{{ post.title }}</h1>

                    <div class="d-flex justify-content-center align-items-center flex-wrap gap-3">
                        <span class="badge bg-light text-primary border border-primary-subtle px-3 py-2">
                            <i class="bi bi-calendar3 me-1"></i> {{ post.createdAt|date('d F Y') }}
                        </span>
                        {% if post.updatedAt %}
                            <span class="badge bg-light text-secondary border border-secondary-subtle px-3 py-2" title="Mis à jour le {{ post.updatedAt|date('d/m/Y H:i') }}">
                                <i class="bi bi-pencil-square me-1"></i> Modifié le {{ post.updatedAt|date('d F Y') }}
                            </span>
                        {% endif %}
                        {% for tag in post.tags %}
                            <twig:TagBadge :tag="tag" class="badge bg-primary-subtle text-primary border border-primary-subtle px-3 py-2 text-decoration-none" />
                        {% endfor %}
                        <span class="text-muted small">
                            <i class="bi bi-clock me-1"></i> {{ (post.content|length / 1000)|round(0, 'ceil') }} min de lecture
                        </span>
                    </div>
                </header>

                <div class="card shadow-sm border-0 mb-5">
                    <div class="card-body p-4 p-md-5">
                        <div class="lead text-secondary mb-0" style="white-space: pre-wrap; line-height: 1.8;">
                            {{ post.content|raw }}
                        </div>
                    </div>
                </div>

                <footer class="d-flex justify-content-between align-items-center py-4 border-top">
                    <div class="d-flex align-items-center gap-3">
                        <div class="d-flex gap-2">
                            {% if (preview is not defined or not preview) and is_granted('ROLE_ADMIN') %}
                                <a href="{{ path('app_post_edit', {'id': post.id}) }}" class="btn btn-outline-primary transition-base">
                                    <i class="bi bi-pencil me-1"></i> Modifier
                                </a>
                                <form method="post" action="{{ path('app_post_delete', {'id': post.id}) }}" onsubmit="return confirm('Supprimer cet article ?');" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ post.id) }}">
                                    <button class="btn btn-outline-danger transition-base" aria-label="Supprimer">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            {% endif %}
                        </div>

                        {% if (preview is not defined or not preview) %}
                            <div class="like-section">
                                <button class="btn {{ isLiked ? 'btn-primary' : 'btn-outline-primary' }} transition-base like-button"
                                        data-controller="like"
                                        data-like-url-value="{{ path('app_post_like', {'id': post.id}) }}"
                                        data-like-liked-value="{{ isLiked ? 'true' : 'false' }}"
                                        data-action="click->like#toggle"
                                        {% if not is_granted('ROLE_USER') %}disabled title="Connectez-vous pour liker"{% endif %}>
                                    <i class="bi {{ isLiked ? 'bi-heart-fill' : 'bi-heart' }} me-1" data-like-target="icon"></i>
                                    <span class="likes-count" data-like-target="count">{{ likesCount }}</span>
                                </button>
                            </div>
                        {% endif %}
                    </div>

                    {% if preview is not defined or not preview %}
                        <twig:ShareButtons :title="post.title" />
                    {% endif %}
                </footer>
            </article>
        </div>
    </div>
{% endblock %}
