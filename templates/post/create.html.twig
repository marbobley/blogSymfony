{% extends 'base.html.twig' %}
{% block container_class %}container-fluid{% endblock %}

{% block title %}Créer un nouvel article{% endblock %}

{% block body %}
    <div class="row">
        <div class="col-12">
            <div class="card animate-fade-in post-form-card">
                <div class="card-body p-4 p-md-5">
                    <div class="post-form-header">
                        <i class="bi bi-pencil-square"></i>
                        <h1>Nouvel Article</h1>
                        <p class="text-muted">Partagez vos idées avec le monde.</p>
                    </div>
                    {{ form_start(form) }}
                    <div class="row">
                        <div class="col-lg-9">
                            <div class="mb-3">
                                {{ form_label(form.title, 'Titre de l\'article', {'label_attr': {'class': 'form-label post-form-label'}}) }}
                                {{ form_widget(form.title, {'attr': {'class': 'form-control post-form-title-input', 'placeholder': 'Entrez le titre...'}}) }}
                                {{ form_errors(form.title) }}
                            </div>

                            <div class="mb-3">
                                {{ form_label(form.sub_title, 'Sous-titre / Chapô', {'label_attr': {'class': 'form-label post-form-label'}}) }}
                                {{ form_widget(form.sub_title, {'attr': {'class': 'form-control', 'rows': 3, 'placeholder': 'Un bref résumé...'}}) }}
                                {{ form_errors(form.sub_title) }}
                            </div>

                            <div class="mb-3" data-controller="html-insert">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    {{ form_label(form.content, 'Contenu', {'label_attr': {'class': 'form-label post-form-label mb-0'}}) }}
                                    <div class="btn-group btn-group-sm" role="group">
                                        <button type="button" class="btn btn-outline-secondary" data-action="click->html-insert#insertImage" title="Insérer une image">
                                            <i class="bi bi-image"></i> Image
                                        </button>
                                        <button type="button" class="btn btn-outline-secondary" data-action="click->html-insert#insertVideo" title="Insérer une vidéo">
                                            <i class="bi bi-play-btn"></i> Vidéo
                                        </button>
                                        <button type="button" class="btn btn-outline-secondary" data-action="click->html-insert#insertBlockquote" title="Insérer une citation">
                                            <i class="bi bi-quote"></i> Citation
                                        </button>
                                    </div>
                                </div>
                                {{ form_widget(form.content, {'attr': {
                                    'class': 'form-control',
                                    'rows': 20,
                                    'placeholder': 'Rédigez votre article ici...',
                                    'data-html-insert-target': 'textarea'
                                }}) }}
                                {{ form_errors(form.content) }}
                            </div>
                        </div>

                        <div class="col-lg-3">
                            <div class="card post-form-sidebar-card">
                                <div class="card-body">
                                    <h5 class="post-form-sidebar-title">Publication</h5>
                                    <div class="form-check form-switch mb-3">
                                        {{ form_widget(form.published, {'attr': {'class': 'form-check-input'}}) }}
                                        {{ form_label(form.published, null, {'label_attr': {'class': 'form-check-label'}}) }}
                                    </div>
                                    <div class="d-grid gap-2">
                                        {{ form_widget(form.save, {'attr': {'class': 'btn btn-primary'}}) }}
                                        {{ form_widget(form.saveAndContinue, {'attr': {'class': 'btn btn-outline-primary'}}) }}
                                        <button type="button"
                                                class="btn btn-outline-info"
                                                data-controller="post-preview"
                                                data-post-preview-url-value="{{ path('app_post_preview') }}"
                                                data-action="click->post-preview#preview">
                                            <i class="bi bi-eye me-1"></i> Prévisualiser
                                        </button>
                                        <a href="{{ path('app_post_admin_index') }}" class="btn btn-outline-secondary btn-sm">Annuler</a>
                                    </div>
                                </div>
                            </div>

                            <div class="card post-form-sidebar-card">
                                <div class="card-body">
                                    <h5 class="post-form-sidebar-title">Tags</h5>
                                    <div class="post-tags-selector">
                                        {{ form_widget(form.tags) }}
                                    </div>
                                    {{ form_errors(form.tags) }}
                                </div>
                            </div>
                        </div>
                    </div>
                    {{ form_end(form) }}

                </div>
            </div>
        </div>
    </div>
{% endblock %}
